{
  "name": "red-cross-evidence",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed:educations": "dotenv npx tsx ./src/server/db/seed/education.seed.ts",
    "db:seed:educationTerms": "dotenv npx tsx ./src/server/db/seed/educationTerm.seed.ts",
    "db:seed:licenses": "dotenv npx tsx ./src/server/db/seed/license.seed.ts",
    "db:seed:users": "dotenv npx tsx ./src/server/db/seed/user.seed.ts",
    "db:seed:societies": "dotenv npx tsx ./src/server/db/seed/society.seed.ts",
    "db:seed:config": "dotenv npx tsx ./src/server/db/seed/config.seed.ts",
    "db:seed:all": "dotenv npx tsx ./src/server/db/seed/index.ts",
    "db:schema:generate": "node --experimental-specifier-resolution=node --loader ts-node/esm src/server/db/dbml-generator/dbml.ts && dbml-renderer -i schema.dbml -o erd.svg",
    "dev": "next dev --turbo",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "start": "next start",
    "postinstall": "rm -rf node_modules/@radix-ui/react-label/node_modules/@radix-ui/react-slot",
    "prepare": "husky",
    "test": "jest --config jest.config.cjs"
  },
